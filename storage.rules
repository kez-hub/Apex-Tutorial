rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    // Allow instructors to upload PDFs for notes
    match /notes/{userId}/{noteId}/{allFiles=**} {
      allow read: if request.auth != null;
      allow write: if request.auth.uid == userId;
    }

    // Allow instructors to upload PDFs for courses
    match /courses/{userId}/{courseId}/{allFiles=**} {
      allow read: if request.auth != null;
      allow write: if request.auth.uid == userId;
    }

    // Allow users to upload avatars
    match /avatars/{userId}/{fileName} {
      allow read: if request.auth != null;
      allow write: if request.auth.uid == userId;
    }

    // Deny all other access
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
