rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /users/{userId}/{documents=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    match /users/{userId} {
      // Allow authenticated users to read their own document
      allow read: if request.auth != null && request.auth.uid == userId;
      // Allow authenticated users to read other user profiles (for instructor info)
      allow read: if request.auth != null;
      // Allow public reads to fetch instructor avatars and names
      allow read: if request.auth == null;
      // Allow authenticated users to update their own data
      allow update: if request.auth != null && request.auth.uid == userId;
      // Allow unauthenticated password reset updates for the specific reset flow
      allow update: if request.auth == null && 
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['passwordHash', 'resetCode', 'resetCodeExpiry']) &&
        resource.data.resetCode != null &&
        resource.data.resetCodeExpiry > request.time &&
        request.resource.data.resetCode == null &&
        request.resource.data.resetCodeExpiry == null &&
        request.resource.data.passwordHash is string;
    }
    match /password-resets/{resetId} {
      // Allow creating and reading password reset documents
      allow create, read: if request.auth == null;
      allow update, delete: if request.auth != null && 
        request.auth.uid == resource.data.userId;
    }
    match /courses/{courseId} {
      // Allow everyone to read courses
      allow read: if true;
      // Allow instructors to update their own courses (including modules)
      allow update: if request.auth != null && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'instructor' &&
        resource.data.instructorId == request.auth.uid;
      // Allow anyone to write courses (for initial seeding)
      // TODO: Restrict this to admin users only in production
      allow write: if true;
    }
    match /notes/{noteId} {
      // Allow everyone to read notes
      allow read: if true;
      // Allow instructors to update their own notes
      allow update: if request.auth != null && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'instructor' &&
        resource.data.instructorId == request.auth.uid;
      // Allow instructors to create and delete their own notes
      allow create, delete: if request.auth != null && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'instructor';
    }
    match /quizzes/{quizId} {
      // Allow everyone to read quizzes
      allow read: if true;
      // Allow instructors to update their own quizzes
      allow update: if request.auth != null && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'instructor' &&
        resource.data.instructorId == request.auth.uid;
      // Allow instructors to create and delete their own quizzes
      allow create, delete: if request.auth != null && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'instructor';
    }
    match /metadata/{document=**} {
      allow read, write: if request.auth != null;
    }
    match /notifications/{userId}/{documents=**} {
      // Allow users to read and delete their own notifications
      allow read, delete: if request.auth != null && request.auth.uid == userId;
      // Allow Cloud Functions to create notifications for students
      allow create: if request.auth == null || request.auth.uid == userId;
    }
    match /messages/{messageId} {
      // Allow users to read messages when they are sender, receiver, or listed in participants
      allow read: if request.auth != null && (
        request.auth.uid == resource.data.senderId ||
        request.auth.uid == resource.data.receiverId ||
        request.auth.uid in resource.data.participants
      );

      // Allow users to create messages only as the sender and when both sender and receiver are part of the participants list
      allow create: if request.auth != null &&
        request.auth.uid == request.resource.data.senderId &&
        request.resource.data.senderId in request.resource.data.participants &&
        request.resource.data.receiverId in request.resource.data.participants;

      // Allow users to update messages they sent (for marking as read)
      allow update: if request.auth != null &&
        request.auth.uid == resource.data.senderId;
    }
  }
}

